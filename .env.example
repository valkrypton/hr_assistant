# ── AI Provider ──────────────────────────────────────────────────────────────
# Choices: ollama | openai | anthropic | xai | qwen
AI_PROVIDER=ollama

# ── Ollama (local) ───────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── xAI (Grok) ───────────────────────────────────────────────────────────────
XAI_API_KEY=xai-...
XAI_MODEL=grok-beta
XAI_BASE_URL=https://api.x.ai/v1

# ── QWEN (Alibaba) ───────────────────────────────────────────────────────────
QWEN_API_KEY=sk-...
QWEN_MODEL=qwen-max
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/company.db

# ── Access control ───────────────────────────────────────────────────────────
# Comma-separated table names the AI must never query (leave blank to allow all)
IGNORED_TABLES=
