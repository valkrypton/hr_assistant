# ── AI Provider ──────────────────────────────────────────────────────────────
# Choices: ollama | openai | anthropic | xai | qwen | librechat
AI_PROVIDER=ollama

# ── Ollama (local) ───────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── xAI (Grok) ───────────────────────────────────────────────────────────────
XAI_API_KEY=xai-...
XAI_MODEL=grok-beta
XAI_BASE_URL=https://api.x.ai/v1

# ── QWEN (Alibaba) ───────────────────────────────────────────────────────────
QWEN_API_KEY=sk-...
QWEN_MODEL=qwen-max
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── LIBRECHAT SELF HOSTED
LIBRECHAT_API_KEY=sk-..
LIBRECHAT_MODEL=gpt-4o-mini
LIBRECHAT_BASE_URL=https://litellm.api.com

# ── Databases ────────────────────────────────────────────────────────────────
# ERP database — read-only. The SQL agent queries this; never written to.
DATABASE_URL=postgresql://user:password@erp-host:5432/erp_db

# App database — writable. Stores hr_assistant_users, audit logs, etc.
# Can be a separate PostgreSQL DB or SQLite for local dev: sqlite:///./data/app.db
APP_DATABASE_URL=postgresql://user:password@app-host:5432/hr_assistant_db

# ── Slack integration ────────────────────────────────────────────────────────
# Get these from https://api.slack.com/apps → your app → Basic Information
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# ── Rate limiting ────────────────────────────────────────────────────────────
# Max queries per registered user per hour. Set to 0 to disable.
RATE_LIMIT_PER_HOUR=30

# ── Admin authentication ──────────────────────────────────────────────────────
# Secret key for signing admin session cookies (/admin panel).
# Use a strong random value in production: openssl rand -hex 32
SECRET_KEY=change-me-in-production
# Create admin users via: python scripts/create_admin.py <username>

# ── Dev / debug ───────────────────────────────────────────────────────────────
# Set DEBUG=true to enable verbose agent SQL logging.
# Set ALLOW_UNAUTHENTICATED_QUERY=true to allow /query without slack_user_id (local dev only).
# DEBUG=false
# ALLOW_UNAUTHENTICATED_QUERY=false

# ── Access control ───────────────────────────────────────────────────────────
# Required. Only these tables are visible to the agent.
# All other tables in the database are invisible to the agent.
INCLUDED_TABLES=person,department,team

# ── Vector index (semantic search) ───────────────────────────────────────────
# Directory to persist the Chroma vector store
VECTOR_STORE_PATH=./data/chroma
# Ollama embedding model (used when AI_PROVIDER=ollama).
# Recommended: pull nomic-embed-text first (274 MB, purpose-built for embeddings):
#   ollama pull nomic-embed-text
# Fallback: any model already installed (e.g. llama3.2:3b)
VECTOR_EMBEDDING_MODEL=nomic-embed-text
