# ── AI Provider ──────────────────────────────────────────────────────────────
# Choices: ollama | openai | anthropic | xai | qwen
AI_PROVIDER=ollama

# ── Ollama (local) ───────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── xAI (Grok) ───────────────────────────────────────────────────────────────
XAI_API_KEY=xai-...
XAI_MODEL=grok-beta
XAI_BASE_URL=https://api.x.ai/v1

# ── QWEN (Alibaba) ───────────────────────────────────────────────────────────
QWEN_API_KEY=sk-...
QWEN_MODEL=qwen-max
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Access control ───────────────────────────────────────────────────────────
# Required. Only these tables are visible to the agent.
# All other tables in the database are invisible to the agent.
INCLUDED_TABLES=person,department,team,designation,employment_type,person_team,leave_record,leave_type,leave_limit,person_leave_limit,holiday_record,person_week_log,person_week_project,competency_role,competency,competency_level,person_competency,users_personresignation,core_personstatushistory,core_personemploymenthistory,core_personemploymenttypehistory,job_requisition,skill_category,person_skill_category,peer_review,annual_review_response
